generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserRole {
  USER
  COACH
  ADMIN
}

enum Sex {
  MALE
  FEMALE
}

enum GoalType {
  FAT_LOSS
  MUSCLE_GAIN
  WEIGHT_LOSS
  MAINTENANCE
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum WorkoutType {
  STRENGTH
  CARDIO
  HIIT
  SPORTS
  MOBILITY
  OTHER
}

//////////////////////////////////////////////////////
// NEXT AUTH
//////////////////////////////////////////////////////

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

//////////////////////////////////////////////////////
// CORE USER
//////////////////////////////////////////////////////

model User {
  id             String            @id @default(cuid())
  email          String            @unique
  emailVerified  DateTime?
  name           String?
  image          String?
  role           UserRole          @default(USER)
  coachCodes     CoachInviteCode[] @relation("CoachCodes")
  usedInviteCode CoachInviteCode?  @relation("UsedCodes")

  coachId           String?
  coach             User?              @relation("CoachClients", fields: [coachId], references: [id])
  clients           User[]             @relation("CoachClients")
  passwordHash      String?
  registrationCodes RegistrationCode[] @relation("CoachRegistrationCodes")
  usedCode          RegistrationCode?  @relation("UsedRegistrationCode")
  subscription      Subscription?

  posts            Post[]          @relation("UserPosts")
  postReactions    PostReaction[]
  comments         Comment[]
  challenges       Challenge[]     @relation("CoachChallenges")
  sentMessages     DirectMessage[] @relation("SentMessages")
  receivedMessages DirectMessage[] @relation("ReceivedMessages")

  accounts Account[]
  sessions Session[]

  profile UserProfile?

  recipes        Recipe[]
  nutritionPlans NutritionPlan[]

  workouts Workout[]

  hydrationLogs HydrationLog[]
  weightLogs    WeightLog[]
  dailyLogs     DailyLog[]

  ingredientOverrides UserIngredientOverride[]

  metabolicProfiles MetabolicProfile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// USER PROFILE
//////////////////////////////////////////////////////

model UserProfile {
  id     String @id @default(cuid())
  userId String @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  age        Int
  heightCm   Float
  weightKg   Float
  bodyFatPct Float?

  sex  Sex
  goal GoalType

  activityFactor      Float @default(1.2)
  metabolicAdjustment Float @default(1.0)

  updatedAt DateTime @updatedAt
}

model CoachInviteCode {
  id      String @id @default(cuid())
  coachId String
  coach   User   @relation("CoachCodes", fields: [coachId], references: [id], onDelete: Cascade)

  code      String    @unique // 8 caracteres alfanuméricos
  expiresAt DateTime
  usedAt    DateTime?
  usedById  String?   @unique
  usedBy    User?     @relation("UsedCodes", fields: [usedById], references: [id])

  createdAt DateTime @default(now())
}

///////////////////////
////SubscriptionStatus
////////////////////////

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIAL
}

enum InviteCodeType {
  COACH
  CLIENT
}

model RegistrationCode {
  id               String         @id @default(cuid())
  code             String         @unique
  type             InviteCodeType
  createdByCoachId String?
  createdByCoach   User?          @relation("CoachRegistrationCodes", fields: [createdByCoachId], references: [id])
  expiresAt        DateTime
  usedAt           DateTime?
  usedById         String?        @unique
  usedBy           User?          @relation("UsedRegistrationCode", fields: [usedById], references: [id])
  maxUses          Int            @default(1)
  useCount         Int            @default(0)
  createdAt        DateTime       @default(now())

  @@index([createdByCoachId, type, usedAt])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  paypalSubscriptionId String?            @unique
  paypalPlanId         String?
  status               SubscriptionStatus @default(TRIAL)
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  clientCodeCredits    Int                @default(5)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

//////////////////////////////////////////////////////
// POSTS
//////////////////////////////////////////////////////

enum PostType {
  CHECKIN // check-in diario con métricas
  ACHIEVEMENT // logro (primera semana, objetivo alcanzado)
  QUESTION // pregunta al coach o comunidad
  CHALLENGE // respuesta a un reto
  SHARE // receta o plan compartido
  FREE // post libre
}

enum PostVisibility {
  PRIVATE // solo el usuario y su coach
  COACH_GROUP // coach + todos sus clientes
  PUBLIC // toda la comunidad
}

model Post {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("UserPosts", fields: [userId], references: [id], onDelete: Cascade)

  type       PostType
  visibility PostVisibility @default(PRIVATE)

  content   String? // texto del post
  imageUrls String[] // array de URLs (UploadThing)

  // Métricas automáticas del día (snapshot si es CHECKIN)
  kcalIn   Float?
  kcalOut  Float?
  balance  Float?
  weightKg Float?
  proteinG Float?

  // Links a contenido de la app
  recipeId   String?
  planId     String?
  dailyLogId String?

  // Coach destacó este post
  featuredBy String?
  featuredAt DateTime?

  // Reto al que responde
  challengeId String?
  challenge   Challenge? @relation(fields: [challengeId], references: [id])

  reactions PostReaction[]
  comments  Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([visibility, createdAt])
}

model PostReaction {
  id     String @id @default(cuid())
  postId String
  userId String
  emoji  String // "❤️" | "🔥" | "🏆" | "💪" | "👏"

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, emoji])
}

model Comment {
  id       String  @id @default(cuid())
  postId   String
  userId   String
  parentId String? // null = top-level, string = respuesta

  content  String
  imageUrl String?

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

model Challenge {
  id      String @id @default(cuid())
  coachId String
  coach   User   @relation("CoachChallenges", fields: [coachId], references: [id])

  title       String
  description String
  imageUrl    String?

  startsAt DateTime
  endsAt   DateTime

  // A quiénes aplica
  targetAll Boolean  @default(false) // todos los clientes del coach
  targetIds String[] // o lista específica de clientIds

  posts Post[]

  createdAt DateTime @default(now())

  @@index([coachId, endsAt])
}

model DirectMessage {
  id     String @id @default(cuid())
  fromId String
  toId   String
  from   User   @relation("SentMessages", fields: [fromId], references: [id])
  to     User   @relation("ReceivedMessages", fields: [toId], references: [id])

  content  String
  imageUrl String?
  readAt   DateTime?

  createdAt DateTime @default(now())

  @@index([fromId, toId, createdAt])
  @@index([toId, readAt])
}

//////////////////////////////////////////////////////
// INGREDIENTS
//////////////////////////////////////////////////////

model Ingredient {
  id   String @id @default(cuid())
  name String @unique

  emoji    String? // "🥦" — fallback visual inmediato
  imageUrl String? // URL de imagen cuando esté disponible

  kcalPer100g       Float
  proteinPer100g    Float
  carbsPer100g      Float
  fatPer100g        Float
  fiberPer100g      Float?
  sodiumMgPer100g   Float?
  micronutrients    Json?
  defaultPricePerKg Float?

  recipeIngredients       RecipeIngredient[]
  userIngredientOverrides UserIngredientOverride[]

  updatedAt DateTime @updatedAt
}

model UserIngredientOverride {
  id           String @id @default(cuid())
  userId       String
  ingredientId String

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  customPricePerKg Float? // null = usar defaultPricePerKg del ingrediente
  isActive         Boolean @default(true) // false = excluido del motor de recetas

  @@unique([userId, ingredientId])
}

//////////////////////////////////////////////////////
// RECIPES
//////////////////////////////////////////////////////

model Recipe {
  id     String @id @default(cuid())
  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?

  baseServings Int
  category     String?
  isPrivate    Boolean @default(false)
  isVegan      Boolean @default(false)
  isVegetarian Boolean @default(false)
  isHealthy    Boolean @default(false)
  isLowCarb    Boolean @default(false)
  isSpicy      Boolean @default(false)
  isQuickMeal  Boolean @default(false)
  imageUrl     String?
  steps        String? // preparation steps

  ingredients RecipeIngredient[]

  mealRecipes MealRecipe[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
}

model RecipeIngredient {
  id           String @id @default(cuid())
  recipeId     String
  ingredientId String

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  gramsInBase Float

  @@unique([recipeId, ingredientId])
  @@index([recipeId])
  @@index([ingredientId])
}

//////////////////////////////////////////////////////
// NUTRITION PLANS
//////////////////////////////////////////////////////

model NutritionPlan {
  id     String @id @default(cuid())
  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  startDate DateTime
  endDate   DateTime

  targetKcal Float

  proteinPct Float
  carbsPct   Float
  fatPct     Float

  days PlanDay[]

  createdAt DateTime @default(now())

  @@index([userId, startDate])
}

model PlanDay {
  id     String @id @default(cuid())
  planId String

  plan NutritionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  date DateTime

  meals Meal[]

  @@unique([planId, date])
  @@index([planId, date])
  @@index([date])
}

model Meal {
  id    String @id @default(cuid())
  dayId String

  day PlanDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  mealType MealType

  recipes MealRecipe[]
}

model MealRecipe {
  id       String @id @default(cuid())
  mealId   String
  recipeId String

  meal   Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id])

  servings Float

  order Int @default(0)
}

//////////////////////////////////////////////////////
// METABOLIC ENGINE
//////////////////////////////////////////////////////

model MetabolicProfile {
  id     String @id @default(cuid())
  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  bmr  Float
  tdee Float

  carbOxidationRate Float?
  fatOxidationRate  Float?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// DAILY ENERGY LOGS
//////////////////////////////////////////////////////

model DailyLog {
  id     String   @id @default(cuid())
  userId String
  date   DateTime @db.Date

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  caloriesIn   Float
  proteinGrams Float
  carbsGrams   Float
  fatGrams     Float

  caloriesOut Float

  balance Float

  estimatedWeightDeltaKg Float

  workouts Workout[]

  @@unique([userId, date])
  @@index([userId, date])
  @@index([userId])
}

//////////////////////////////////////////////////////
// WORKOUTS
//////////////////////////////////////////////////////

model Workout {
  id     String @id @default(cuid())
  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  date DateTime

  type WorkoutType

  durationMinutes Float
  intensityFactor Float

  estimatedKcal Float
  realKcal      Float?

  dailyLogId String?
  dailyLog   DailyLog? @relation(fields: [dailyLogId], references: [id])

  sessions WorkoutSession[]

  createdAt DateTime @default(now())

  @@index([userId, date])
  @@index([dailyLogId])
}

model WorkoutSession {
  id String @id @default(uuid())

  workoutId String

  workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// HYDRATION
//////////////////////////////////////////////////////

model HydrationLog {
  id     String   @id @default(cuid())
  userId String
  date   DateTime @db.Date

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  waterMl Float

  @@unique([userId, date])
  @@index([userId, date])
}

//////////////////////////////////////////////////////
// WEIGHT
//////////////////////////////////////////////////////

model WeightLog {
  id     String   @id @default(cuid())
  userId String
  date   DateTime @db.Date

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  weightKg Float

  @@unique([userId, date])
  @@index([userId, date])
}
